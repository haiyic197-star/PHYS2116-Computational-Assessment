# First import the necessary libraries for analysing the data and plotting the results.
import os
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt

from scipy.stats import pearsonr, spearmanr
import statsmodels.api as sm

plt.rcParams["figure.dpi"] = 140
pd.set_option("display.max_columns", 100)

# Check current working directory
print("Current working directory:", os.getcwd())

# Read the CSV file
file_path = "PSCompPars_2026.03.15_01.30.06.csv"

# Check whether the file exists
if not os.path.exists(file_path):
    raise FileNotFoundError(f"Cannot find file: {file_path}")

# Read data
raw = pd.read_csv(file_path, comment="#", low_memory=False)

# Basic inspection
print("Raw shape:", raw.shape)
print(raw.head())
print(raw.columns.tolist())

#Only keep the columns we need for our analysis
keep_cols = [
    "pl_name",
    "hostname",
    "tran_flag",
    "pl_radj",
    "pl_radjerr1",
    "pl_radjerr2",
    "pl_orbper",
    "pl_orbpererr1",
    "pl_orbpererr2",
    "pl_eqt",
    "pl_eqterr1",
    "pl_eqterr2",
    "pl_insol",
    "pl_insolerr1",
    "pl_insolerr2",
    "pl_bmassj",
    "pl_bmassjerr1",
    "pl_bmassjerr2",
    "st_mass",
    "st_masserr1",
    "st_masserr2",
    "st_met",
    "st_meterr1",
    "st_meterr2",
    "st_teff",
    "st_rad",
    "pl_dens"
]

df = raw[keep_cols].copy()
print(df.shape)
df.head()

# Convert columns to numeric, coercing errors to NaN
text_cols = ["pl_name", "hostname"]
num_cols = [c for c in df.columns if c not in text_cols]

for col in num_cols:
    df[col] = pd.to_numeric(df[col], errors="coerce")

df.dtypes

# Screening “well-characterised transiting hot Jupiters”
sample = df[
    (df["tran_flag"] == 1) &
    (df["pl_orbper"] <= 10) &
    (df["pl_bmassj"] >= 0.3) &
    (df["pl_bmassj"] <= 13) &
    df[["pl_radj", "pl_eqt", "pl_insol", "st_mass", "st_met"]].notna().all(axis=1) &
    (df["pl_eqt"] > 0) &
    (df["pl_insol"] > 0)
].copy()

print("Filtered sample shape:", sample.shape)
sample.head()

# Quickly check the distributions of key parameters
print(sample[["pl_radj", "pl_orbper", "pl_eqt", "pl_insol", "pl_bmassj", "st_mass", "st_met"]].describe())
sample[["pl_name", "pl_radj", "pl_orbper", "pl_eqt", "pl_insol", "pl_bmassj"]].sort_values("pl_radj", ascending=False).head(10)

# Save the filtered sample for later use
sample.to_csv("topic2_hot_jupiters_clean.csv", index=False)
print("Saved: topic2_hot_jupiters_clean.csv")

# Plot the diagram "Planet radius vs equilibrium temperature"
os.makedirs("figures", exist_ok=True)

plt.figure(figsize=(8, 5))
plt.scatter(sample["pl_eqt"], sample["pl_radj"], alpha=0.7)

# 1.0 RJ is approximately equivalent to the benchmark of an ordinary gas giant.
plt.axhline(1.0, linestyle="--")
# 1.2 The RJ value can be regarded as a simple reference threshold for inflation.(Diafgram 1))
plt.axhline(1.2, linestyle=":")

plt.xlabel("Equilibrium temperature (K)")
plt.ylabel("Planet radius (Rj)")
plt.title("Planet radius vs equilibrium temperature")
plt.tight_layout()
plt.savefig("figures/01_radius_vs_teq.png", bbox_inches="tight")
plt.show()

# Viewing "transition" through the binning method makes it clearer (Diagram 2)
sample["temp_bin"] = pd.qcut(sample["pl_eqt"], q=10, duplicates="drop")

temp_summary = (
    sample.groupby("temp_bin", observed=False)
    .agg(
        teq_mid=("pl_eqt", "median"),
        rad_med=("pl_radj", "median"),
        rad_std=("pl_radj", "std"),
        n=("pl_radj", "size")
    )
    .dropna()
)

temp_summary["rad_sem"] = temp_summary["rad_std"] / np.sqrt(temp_summary["n"])

print(temp_summary)
plt.figure(figsize=(8, 5))
plt.errorbar(
    temp_summary["teq_mid"],
    temp_summary["rad_med"],
    yerr=temp_summary["rad_sem"],
    fmt="o-"
)

plt.axhline(1.0, linestyle="--")
plt.axhline(1.2, linestyle=":")

plt.xlabel("Equilibrium temperature (K)")
plt.ylabel("Median planet radius (Rj)")
plt.title("Binned trend: radius vs equilibrium temperature")
plt.tight_layout()
plt.savefig("figures/02_binned_radius_vs_teq.png", bbox_inches="tight")
plt.show()

# Perform a simple transition scan (Diagram 3)
thresholds = np.arange(800, 2501, 50)
rows = []

for T in thresholds:
    cool = sample.loc[sample["pl_eqt"] < T, "pl_radj"].dropna()
    hot = sample.loc[sample["pl_eqt"] >= T, "pl_radj"].dropna()
    
    if len(cool) >= 20 and len(hot) >= 20:
        rows.append({
            "T_threshold": T,
            "mean_radius_cool": cool.mean(),
            "mean_radius_hot": hot.mean(),
            "radius_jump": hot.mean() - cool.mean()
        })

transition_df = pd.DataFrame(rows)
print(transition_df.head())
plt.figure(figsize=(8, 5))
plt.plot(transition_df["T_threshold"], transition_df["radius_jump"])
plt.xlabel("Temperature threshold (K)")
plt.ylabel("Mean radius difference (hot - cool) [Rj]")
plt.title("Heuristic scan for transition temperature")
plt.tight_layout()
plt.savefig("figures/03_transition_scan.png", bbox_inches="tight")
plt.show()

best_row = transition_df.loc[transition_df["radius_jump"].idxmax()]
print("Heuristic transition temperature ~", best_row["T_threshold"], "K")

#Incident flux influence (Diagram 4)
plt.figure(figsize=(8, 5))
plt.scatter(sample["pl_insol"], sample["pl_radj"], alpha=0.7)
plt.xscale("log")
plt.axhline(1.0, linestyle="--")
plt.axhline(1.2, linestyle=":")

plt.xlabel("Incident flux (Earth flux units)")
plt.ylabel("Planet radius (Rj)")
plt.title("Planet radius vs incident flux")
plt.tight_layout()
plt.savefig("figures/04_radius_vs_flux.png", bbox_inches="tight")
plt.show()

#Calculate the coefficient of correlation of radius and flux
flux_x = np.log10(sample["pl_insol"])
rad_y = sample["pl_radj"]

pear_r, pear_p = pearsonr(flux_x, rad_y)
spear_rho, spear_p = spearmanr(flux_x, rad_y)

print("Radius vs log10(flux)")
print("Pearson r =", pear_r, "p =", pear_p)
print("Spearman rho =", spear_rho, "p =", spear_p)

# Host0-star mass vs metalicity(Diagram 5)
fig, axes = plt.subplots(1, 2, figsize=(12, 5))

axes[0].scatter(sample["st_mass"], sample["pl_radj"], alpha=0.7)
axes[0].set_xlabel("Host star mass (Msun)")
axes[0].set_ylabel("Planet radius (Rj)")
axes[0].set_title("Radius vs host star mass")

axes[1].scatter(sample["st_met"], sample["pl_radj"], alpha=0.7)
axes[1].set_xlabel("Host star metallicity [Fe/H]")
axes[1].set_ylabel("Planet radius (Rj)")
axes[1].set_title("Radius vs host star metallicity")

plt.tight_layout()
plt.savefig("figures/05_radius_vs_host_properties.png", bbox_inches="tight")
plt.show()

#Calculate correlation coefficients for host star mass and metallicity
for xcol in ["st_mass", "st_met"]:
    x = sample[xcol]
    y = sample["pl_radj"]

    pear_r, pear_p = pearsonr(x, y)
    spear_rho, spear_p = spearmanr(x, y)

    print(f"\nRadius vs {xcol}")
    print("Pearson r =", pear_r, "p =", pear_p)
    print("Spearman rho =", spear_rho, "p =", spear_p)

#Perform a simple linear regression of radius on log(flux), host mass, and metallicity
reg_df = sample[["pl_radj", "pl_insol", "st_mass", "st_met"]].dropna().copy()
reg_df["log_insol"] = np.log10(reg_df["pl_insol"])

X = reg_df[["log_insol", "st_mass", "st_met"]]
X = sm.add_constant(X)
y = reg_df["pl_radj"]

model = sm.OLS(y, X).fit()
print(model.summary())

#Observatioanl uncertainties
mc = sample[
    [
        "pl_radj", "pl_radjerr1", "pl_radjerr2",
        "pl_insol", "pl_insolerr1", "pl_insolerr2",
        "st_mass", "st_masserr1", "st_masserr2",
        "st_met", "st_meterr1", "st_meterr2"
    ]
].dropna().copy()

def symmetric_sigma(err_plus, err_minus):
    return (np.abs(err_plus) + np.abs(err_minus)) / 2

mc["pl_radj_sigma"] = symmetric_sigma(mc["pl_radjerr1"], mc["pl_radjerr2"])
mc["pl_insol_sigma"] = symmetric_sigma(mc["pl_insolerr1"], mc["pl_insolerr2"])
mc["st_mass_sigma"] = symmetric_sigma(mc["st_masserr1"], mc["st_masserr2"])
mc["st_met_sigma"] = symmetric_sigma(mc["st_meterr1"], mc["st_meterr2"])

# Avoid sigma=0 or nan
for c in ["pl_radj_sigma", "pl_insol_sigma", "st_mass_sigma", "st_met_sigma"]:
    mc[c] = mc[c].replace(0, np.nan)

mc = mc.dropna().copy()
print("MC sample size:", len(mc))
rng = np.random.default_rng(42)

n_iter = 1000
r_flux_list = []
r_mass_list = []
r_met_list = []

for _ in range(n_iter):
    rad_draw = rng.normal(mc["pl_radj"], mc["pl_radj_sigma"])
    flux_draw = rng.normal(mc["pl_insol"], mc["pl_insol_sigma"])
    mass_draw = rng.normal(mc["st_mass"], mc["st_mass_sigma"])
    met_draw = rng.normal(mc["st_met"], mc["st_met_sigma"])
    
    good_flux = flux_draw > 0
    
    if good_flux.sum() > 10:
        r_flux = np.corrcoef(np.log10(flux_draw[good_flux]), rad_draw[good_flux])[0, 1]
        r_flux_list.append(r_flux)
    
    r_mass = np.corrcoef(mass_draw, rad_draw)[0, 1]
    r_met = np.corrcoef(met_draw, rad_draw)[0, 1]
    
    r_mass_list.append(r_mass)
    r_met_list.append(r_met)

print("Flux correlation median:", np.median(r_flux_list))
print("Flux correlation 16-84%:", np.percentile(r_flux_list, [16, 84]))

print("Mass correlation median:", np.median(r_mass_list))
print("Mass correlation 16-84%:", np.percentile(r_mass_list, [16, 84]))

print("Metallicity correlation median:", np.median(r_met_list))
print("Metallicity correlation 16-84%:", np.percentile(r_met_list, [16, 84]))

#Ploting the uncertainty distributions
plt.figure(figsize=(8, 5))
plt.hist(r_flux_list, bins=30, alpha=0.8)
plt.xlabel("Correlation coefficient: radius vs log10(flux)")
plt.ylabel("Count")
plt.title("Monte Carlo uncertainty test")
plt.tight_layout()
plt.savefig("figures/06_mc_flux_correlation.png", bbox_inches="tight")
plt.show()

